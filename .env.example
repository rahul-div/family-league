# ============================================================
# Family League - Environment Variables
# ============================================================
# Copy this file to .env and update the values for your setup.
#
# HOW TO USE:
#   cp .env.example .env
#   # Edit .env with your values
#   source .env
#   ./mvnw spring-boot:run
# ============================================================

# --- DATABASE (Required) ---
# PostgreSQL connection details.
# Create the database first: psql -U postgres -c "CREATE DATABASE family_league;"
DB_URL=jdbc:postgresql://localhost:5432/family_league
DB_USERNAME=postgres
DB_PASSWORD=postgres

# --- JWT (Optional — has secure default) ---
# Base64-encoded secret key for signing JWT tokens.
# To generate your own: openssl rand -base64 64
# IMPORTANT: Change this in production!
JWT_SECRET=ZmFtaWx5LWxlYWd1ZS1zZWNyZXQta2V5LXRoYXQtaXMtYXQtbGVhc3Qtc2l4dHktZm91ci1jaGFyYWN0ZXJzLWxvbmc=

# JWT token expiration in milliseconds (default: 24 hours)
JWT_EXPIRATION_MS=86400000

# --- EMAIL (Optional — leave blank for simulated mode) ---
# When MAIL_USERNAME is empty, emails are logged to console instead of sent.
# For real email, use Gmail App Password or any SMTP provider.
#
# Gmail setup:
#   1. Enable 2FA on your Google account
#   2. Go to: https://myaccount.google.com/apppasswords
#   3. Create an "App Password" for "Mail"
#   4. Use that 16-char password below
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=

# --- NOTIFICATION (Optional — has defaults) ---
# Admin notification email address
ADMIN_EMAIL=admin@familyleague.com
# "From" address for outgoing emails
FROM_EMAIL=noreply@familyleague.com

# --- SERVER (Optional — has defaults) ---
# Server port (default: 8080)
SERVER_PORT=8080

# --- HTTPS (Optional — only needed if running with HTTPS profile) ---
# Generate cert first: see README.md HTTPS section
# SSL_KEYSTORE_PASSWORD=changeit
# SSL_KEY_ALIAS=familyleague
